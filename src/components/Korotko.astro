---
// Korotko.astro — блок «Коротко» для статей
interface Props {
  title?: string;
}
const { title = "Коротко" } = Astro.props;
---

<aside class="korotko">
  <div class="korotko__header">
    <span class="korotko__icon" aria-hidden="true">
      <svg width="18" height="18" viewBox="0 0 24 24" fill="none"
           stroke="currentColor" stroke-width="2.2"
           stroke-linecap="round" stroke-linejoin="round">
        <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/>
        <polyline points="14 2 14 8 20 8"/>
        <line x1="16" y1="13" x2="8" y2="13"/>
        <line x1="16" y1="17" x2="8" y2="17"/>
        <polyline points="10 9 9 9 8 9"/>
      </svg>
    </span>
    <span class="korotko__title">{title}</span>
  </div>
  <div class="korotko__body">
    <slot />
  </div>
</aside>

<style>
  .korotko {
    --k-accent: #2563eb;
    --k-accent-light: #dbeafe;
    --k-border: #bfdbfe;
    --k-bg: #f8faff;
    --k-text: #1e293b;
    --k-muted: #475569;

    position: relative;
    margin: 2rem 0 2.5rem;
    background: var(--k-bg);
    border: 1px solid var(--k-border);
    border-radius: 12px;
    overflow: hidden;
    box-shadow: 0 1px 4px rgba(37, 99, 235, 0.07), 0 4px 24px rgba(37, 99, 235, 0.04);
  }

  /* Вертикальная акцентная полоса слева */
  .korotko::before {
    content: "";
    position: absolute;
    left: 0;
    top: 0;
    bottom: 0;
    width: 4px;
    background: linear-gradient(180deg, #2563eb 0%, #60a5fa 100%);
    border-radius: 12px 0 0 12px;
  }

  .korotko__header {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.75rem 1.25rem 0.65rem 1.5rem;
    background: var(--k-accent-light);
    border-bottom: 1px solid var(--k-border);
  }

  .korotko__icon {
    display: flex;
    align-items: center;
    color: var(--k-accent);
    flex-shrink: 0;
  }

  .korotko__title {
    font-size: 0.7rem;
    font-weight: 700;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--k-accent);
    font-family: ui-monospace, "Cascadia Code", "Fira Code", monospace;
  }

  .korotko__body {
    padding: 1.25rem 1.5rem 1.25rem 1.5rem;
    color: var(--k-text);
    font-size: 0.97rem;
    line-height: 1.75;
  }

  /* Типографика внутри блока */
  .korotko__body :global(p) {
    margin: 0 0 0.85rem;
    color: var(--k-muted);
  }

  .korotko__body :global(p:last-child) {
    margin-bottom: 0;
  }

  .korotko__body :global(ul) {
    margin: 0.5rem 0 0.85rem;
    padding-left: 0;
    list-style: none;
  }

  .korotko__body :global(li) {
    position: relative;
    padding-left: 1.4rem;
    margin-bottom: 0.4rem;
    color: var(--k-text);
    font-style: italic;
  }

  /* Кастомный маркер */
  .korotko__body :global(li)::before {
    content: "›";
    position: absolute;
    left: 0;
    color: var(--k-accent);
    font-weight: 700;
    font-size: 1.1em;
    line-height: 1.6;
  }

  .korotko__body :global(strong) {
    color: var(--k-accent);
    font-weight: 600;
  }

  /* Тёмная тема */
  @media (prefers-color-scheme: dark) {
    .korotko {
      --k-accent: #60a5fa;
      --k-accent-light: #1e3a5f22;
      --k-border: #1e40af44;
      --k-bg: #0f172a;
      --k-text: #e2e8f0;
      --k-muted: #94a3b8;
    }
  }
</style>
