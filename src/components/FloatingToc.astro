---
// FloatingToc.astro — плавающее содержание статьи
---

<div id="floating-toc-wrapper">
  <!-- Кнопка-таб -->
  <button id="floating-toc-tab" aria-label="Открыть содержание" aria-expanded="false">
    <span class="ftoc-tab-icon" aria-hidden="true">
      <svg width="14" height="14" viewBox="0 0 14 14" fill="none">
        <rect x="0" y="1" width="14" height="2" rx="1" fill="currentColor"/>
        <rect x="3" y="6" width="11" height="2" rx="1" fill="currentColor"/>
        <rect x="6" y="11" width="8" height="2" rx="1" fill="currentColor"/>
      </svg>
    </span>
    СОДЕРЖАНИЕ
  </button>

  <!-- Панель содержания -->
  <div id="floating-toc-panel" role="navigation" aria-label="Содержание статьи">
    <div class="ftoc-header">
      <span class="ftoc-header-title">Содержание</span>
      <button class="ftoc-close" id="floating-toc-close" aria-label="Закрыть">✕</button>
    </div>
    <nav id="floating-toc-nav"></nav>
  </div>
</div>

<style is:global>
  /* ─── Обёртка ─────────────────────────────────────────── */
  #floating-toc-wrapper {
    display: none;
    position: fixed;
    top: 50%;
    right: 0;
    transform: translateY(-50%);
    z-index: 200;
    font-family: ui-monospace, 'IBM Plex Mono', SFMono-Regular, Menlo, monospace;
  }

  @media (min-width: 1100px) {
    #floating-toc-wrapper { display: block; }
  }

  /* ─── Кнопка-таб ──────────────────────────────────────── */
  #floating-toc-tab {
    position: absolute;
    right: 0;
    top: 50%;
    transform: translateY(-50%);
    display: flex;
    flex-direction: row;
    align-items: center;
    justify-content: flex-start;
    gap: 8px;

    writing-mode: vertical-rl;
    text-orientation: mixed;

    padding: 12px 6px;
    border: 1.5px dashed;
    border-right: none;
    border-radius: 9px 0 0 9px;
    cursor: pointer;
    font-size: 10px;
    font-weight: 700;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    font-family: inherit;
    transition: all 0.25s cubic-bezier(.4, 0, .2, 1);
    z-index: 2;
    white-space: nowrap;

    /* Светлая тема */
    background: #eff3ff;
    color: #3245ff;
    border-color: #93c5fd;
    box-shadow: -4px 0 16px rgba(50, 69, 255, 0.09);
  }

  /* Свёрнутое состояние (когда прокрутили глубоко) */
  #floating-toc-tab.ftoc-minimized:not(.ftoc-open) {
    transform: translateY(-50%) translateX(calc(100% - 6px));
    opacity: 0.7;
    box-shadow: -2px 0 8px rgba(50, 69, 255, 0.15);
  }

  #floating-toc-tab.ftoc-minimized:not(.ftoc-open):hover {
    transform: translateY(-50%) translateX(0);
    opacity: 1;
    transition-duration: 0.15s;
  }

  #floating-toc-tab:hover {
    transform: translateY(-50%) translateX(-2px);
    box-shadow: -6px 0 20px rgba(50, 69, 255, 0.15);
    background: #e0e8ff;
  }

  #floating-toc-tab.ftoc-open {
    /* background: #3245ff;
    color: #fff;
    border-color: #3245ff;
    opacity: 0.2; */
    opacity: 0;
    pointer-events: none;
    transition: opacity 0.1s ease-out;
  }

  /* Тёмная тема — кнопка */
  [data-theme="dark"] #floating-toc-tab {
    background: #1b1e28;
    color: #ff5d01;
    border-color: #ff5d01;
    box-shadow: -4px 0 16px rgba(255, 93, 1, 0.12);
  }

  [data-theme="dark"] #floating-toc-tab.ftoc-minimized:not(.ftoc-open) {
    box-shadow: -2px 0 12px rgba(255, 93, 1, 0.2);
  }

  [data-theme="dark"] #floating-toc-tab:hover {
    background: #252938;
    box-shadow: -6px 0 20px rgba(255, 93, 1, 0.2);
  }

  [data-theme="dark"] #floating-toc-tab.ftoc-open {
    /* background: #ff5d01;
    color: #13151a;
    border-color: #ff5d01;
    opacity: 0.2; */
    opacity: 0;
    pointer-events: none;
    transition: opacity 0.1s ease-out;
  }

  .ftoc-tab-icon {
    writing-mode: horizontal-tb;
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
  }

  /* ─── Панель ──────────────────────────────────────────── */
  #floating-toc-panel {
    position: absolute;
    right: 0;
    top: 50%;
    width: 286px;
    max-height: 72vh;
    border-radius: 10px 0 0 10px;
    border: 1.5px dashed;
    border-right: none;
    overflow-y: auto;

    transform-origin: right center;
    transform: translateY(-50%) scaleX(0) scaleY(.08);
    opacity: 0;
    pointer-events: none;
    transition: opacity 0.25s ease;

    /* Светлая тема */
    background: #f4f6ff;
    border-color: #93c5fd;
    box-shadow: -8px 0 32px rgba(50, 69, 255, 0.09);
  }

  #floating-toc-panel.ftoc-open {
    transform: translateY(-50%) scaleX(1) scaleY(1);
    opacity: 1;
    pointer-events: all;
  }

  #floating-toc-panel.ftoc-opening {
    animation: ftocExpand .36s cubic-bezier(.34, 1.1, .64, 1) forwards;
  }

  #floating-toc-panel.ftoc-closing {
    animation: ftocSuck .30s cubic-bezier(.5, 0, 1, .55) forwards;
    pointer-events: none;
  }

  @keyframes ftocExpand {
    0%   { transform: translateY(-50%) scaleX(0) scaleY(.08);         opacity: 0;   border-radius: 80px 0 0 80px; }
    35%  {                                                              opacity: .55; border-radius: 30px 0 0 30px; }
    75%  { transform: translateY(-50%) scaleX(1.03) scaleY(1.01);     opacity: .95; }
    100% { transform: translateY(-50%) scaleX(1) scaleY(1);           opacity: 1;   border-radius: 10px 0 0 10px; }
  }

  @keyframes ftocSuck {
    0%   { transform: translateY(-50%) scaleX(1) scaleY(1);           opacity: 1;   border-radius: 10px 0 0 10px; }
    20%  {                                                              opacity: .9;  border-radius: 22px 0 0 22px; }
    65%  { transform: translateY(-50%) scaleX(.05) scaleY(.42);       opacity: .3;  border-radius: 60px 0 0 60px; }
    100% { transform: translateY(-50%) scaleX(0) scaleY(.08);         opacity: 0;   border-radius: 80px 0 0 80px; }
  }

  /* Таб: «поглощение» после того как панель схлопнулась */
  @keyframes ftocAbsorb {
    0%   { transform: translateY(-50%); }
    40%  { transform: translateY(-50%) translateX(-2.5px) scaleX(1.09) scaleY(1.04); }
    70%  { transform: translateY(-50%) translateX(-0.4px) scaleX(0.99); }
    100% { transform: translateY(-50%); }
  }

  #floating-toc-panel::-webkit-scrollbar { width: 3px; }
  #floating-toc-panel::-webkit-scrollbar-thumb {
    background: #93c5fd;
    border-radius: 2px;
  }

  /* Тёмная тема — панель */
  [data-theme="dark"] #floating-toc-panel {
    background: #0f1220;
    border-color: #ff5d01;
    box-shadow: -8px 0 32px rgba(255, 93, 1, 0.12);
  }

  [data-theme="dark"] #floating-toc-panel::-webkit-scrollbar-thumb {
    background: #ff5d01;
  }

  /* ─── Шапка панели ────────────────────────────────────── */
  .ftoc-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 12px 15px 11px;
    border-bottom: 1px dashed rgba(147, 197, 253, 0.6);
    position: sticky;
    top: 0;
    background: inherit;
    backdrop-filter: blur(4px);
  }

  [data-theme="dark"] .ftoc-header {
    border-bottom-color: rgba(255, 93, 1, 0.4);
  }

  .ftoc-header-title {
    font-size: 10px;
    font-weight: 700;
    letter-spacing: 0.13em;
    text-transform: uppercase;
    color: #3245ff;
  }

  [data-theme="dark"] .ftoc-header-title {
    color: #ff5d01;
  }

  .ftoc-close {
    background: none;
    border: none;
    cursor: pointer;
    color: #737373;
    padding: 2px;
    display: flex;
    align-items: center;
    font-size: 16px;
    line-height: 1;
    font-family: inherit;
    transition: color 0.15s;
  }
  .ftoc-close:hover { color: #3245ff; }

  [data-theme="dark"] .ftoc-close:hover {
    color: #ff5d01;
  }

  /* ─── Навигация (ссылки создаются динамически через JS) ─ */
  #floating-toc-nav { padding: 8px 0 12px; }

  #floating-toc-nav a {
    display: block;
    padding: 5px 15px;
    font-size: 12px;
    line-height: 1.45;
    color: #737373;
    text-decoration: none;
    border-left: 2px solid transparent;
    transition: all 0.15s ease;
    scroll-margin-top: 40px;
  }

  #floating-toc-nav a:hover {
    color: #3245ff;
    border-left-color: rgba(50, 69, 255, 0.5);
    background: rgba(50, 69, 255, 0.05);
  }

  #floating-toc-nav a.ftoc-active {
    color: #3245ff;
    border-left-color: #3245ff;
    font-weight: 600;
    background: rgba(50, 69, 255, 0.05);
  }

  #floating-toc-nav a[data-d="3"] {
    padding-left: 26px;
    font-size: 11.5px;
  }

  #floating-toc-nav a[data-d="4"] {
    padding-left: 36px;
    font-size: 11px;
  }

  /* Тёмная тема — навигация */
  [data-theme="dark"] #floating-toc-nav a {
    color: #636d91;
  }

  [data-theme="dark"] #floating-toc-nav a:hover,
  [data-theme="dark"] #floating-toc-nav a.ftoc-active {
    color: #ff5d01 !important;
    border-left-color: #ff5d01;
    background: rgba(255, 93, 1, 0.07);
  }

  [data-theme="dark"] #floating-toc-nav a[data-d="3"] {
    color: #4a5270;
  }
</style>

<script is:inline data-astro-rerun>
  (function () {
    var wrapper  = document.getElementById('floating-toc-wrapper');
    var tab      = document.getElementById('floating-toc-tab');
    var panel    = document.getElementById('floating-toc-panel');
    var nav      = document.getElementById('floating-toc-nav');
    var closeBtn = document.getElementById('floating-toc-close');

    if (!wrapper || !tab || !panel || !nav) return;

    // Ищем контейнер статьи
    var article =
      document.querySelector('article .prose') ||
      document.querySelector('article') ||
      document.querySelector('[data-pagefind-body]') ||
      document.querySelector('main .prose') ||
      document.querySelector('main');

    if (!article) return;

    var headings = [];
    var all = article.querySelectorAll('h2, h3, h4');
    for (var i = 0; i < all.length; i++) {
      if (all[i].id) headings.push(all[i]);
    }

    if (headings.length < 2) return;

    // Очистим nav на случай повторного запуска
    nav.innerHTML = '';

    // Ссылка на "Начало"
    var startLink = document.createElement('a');
    startLink.href = '#';
    startLink.textContent = 'Начало';
    startLink.setAttribute('data-id', 'ftoc-start');
    startLink.setAttribute('data-d', '2');
    startLink.addEventListener('click', function(e) {
      e.preventDefault();
      window.scrollTo({ top: 0, behavior: 'smooth' });
    });
    nav.appendChild(startLink);

    // Маркер для начала статьи (чтобы подсвечивать "Начало")
    var topMarker = document.createElement('div');
    topMarker.id = 'ftoc-top-marker';
    topMarker.style.visibility = 'hidden';
    topMarker.style.position = 'absolute';
    topMarker.style.top = '0';
    article.style.position = article.style.position || 'relative';
    article.prepend(topMarker);

    // Построим список ссылок
    headings.forEach(function(h) {
      // Пропускаем "Footnotes", если такой заголовок попался
      var text = '';
      for (var j = 0; j < h.childNodes.length; j++) {
        var node = h.childNodes[j];
        if (node.nodeType === 3) {
          text += node.textContent;
        } else if (node.nodeType === 1) {
          if (!node.classList || !node.classList.contains('heading-link')) {
            text += node.textContent;
          }
        }
      }
      var cleanText = text.trim();
      if (cleanText.toLowerCase() === 'footnotes') return;

      var a = document.createElement('a');
      a.href = '#' + h.id;
      a.textContent = cleanText;
      a.setAttribute('data-id', h.id);
      a.setAttribute('data-d', h.tagName[1]); // '2', '3', '4'

      a.addEventListener('click', function(e) {
        e.preventDefault();
        var target = document.getElementById(h.id);
        if (target) target.scrollIntoView({ behavior: 'smooth' });
      });

      nav.appendChild(a);
    });

    // Ссылка на "Источники" (если есть id="fn-sources")
    var sourcesEl = document.getElementById('fn-sources');
    if (sourcesEl) {
      var sourcesLink = document.createElement('a');
      sourcesLink.href = '#fn-sources';
      sourcesLink.textContent = 'Источники';
      sourcesLink.setAttribute('data-id', 'fn-sources');
      sourcesLink.setAttribute('data-d', '2');
      sourcesLink.addEventListener('click', function(e) {
        e.preventDefault();
        sourcesEl.scrollIntoView({ behavior: 'smooth' });
      });
      nav.appendChild(sourcesLink);
    }

    // Открыть / закрыть
    function openPanel() {
      if (panel.classList.contains('ftoc-open')) return;
      tab.classList.add('ftoc-open');        // прячем таб
      panel.classList.remove('ftoc-closing');
      void panel.offsetWidth;               // reflow — сбрасываем анимацию
      panel.classList.add('ftoc-opening');
      panel.addEventListener('animationend', function h() {
        panel.classList.remove('ftoc-opening');
        panel.classList.add('ftoc-open');
        panel.removeEventListener('animationend', h);
      }, { once: true });
    }

    function closePanel() {
      if (!panel.classList.contains('ftoc-open') && !panel.classList.contains('ftoc-opening')) return;
      panel.classList.remove('ftoc-open');
      panel.classList.remove('ftoc-opening');
      panel.classList.add('ftoc-closing');

      // Начинаем показывать таб раньше, чем закончится анимация панели (через ~180мс)
      // Вся анимация панели ftocSuck длится 300мс
      setTimeout(function() {
        if (!panel.classList.contains('ftoc-closing')) return; // защита от быстрого ре-опена
        
        tab.classList.remove('ftoc-open');
        tab.style.animation = 'ftocAbsorb .44s cubic-bezier(.34, 1.56, .64, 1) forwards';
        
        var th = function() {
          tab.style.animation = '';
          tab.removeEventListener('animationend', th);
        };
        tab.addEventListener('animationend', th, { once: true });
      }, 180);

      panel.addEventListener('animationend', function h() {
        panel.classList.remove('ftoc-closing');
        panel.removeEventListener('animationend', h);
      }, { once: true });
    }

    tab.addEventListener('click', function() {
      panel.classList.contains('ftoc-open') ? closePanel() : openPanel();
    });
    if (closeBtn) closeBtn.addEventListener('click', closePanel);

    document.addEventListener('click', function(e) {
      if (!panel.contains(e.target) && !tab.contains(e.target)) {
        closePanel();
      }
    });
    document.addEventListener('keydown', function(e) {
      if (e.key === 'Escape') closePanel();
    });

    // Подсветка активного раздела
    var links = nav.querySelectorAll('a');

    var observer = new IntersectionObserver(function(entries) {
      entries.forEach(function(entry) {
        if (entry.isIntersecting) {
          var id = (entry.target.id === 'ftoc-top-marker') ? 'ftoc-start' : entry.target.id;
          
          // Определяем, нужно ли свернуть таб (если мы ушли дальше первого заголовка)
          var isAtStart = (id === 'ftoc-start');
          var isAtFirstHeading = (headings.length > 0 && id === headings[0].id);
          
          if (isAtStart || isAtFirstHeading) {
            tab.classList.remove('ftoc-minimized');
          } else {
            tab.classList.add('ftoc-minimized');
          }

          for (var k = 0; k < links.length; k++) {
            if (links[k].getAttribute('data-id') === id) {
              links[k].classList.add('ftoc-active');
              links[k].scrollIntoView({ block: 'start', behavior: 'smooth' });
            } else {
              links[k].classList.remove('ftoc-active');
            }
          }
        }
      });
    }, { rootMargin: '0px 0px -55% 0px', threshold: 0 });

    observer.observe(topMarker);
    headings.forEach(function(h) { observer.observe(h); });
    if (sourcesEl) observer.observe(sourcesEl);
  })();
</script>
