---
// Remove current url path and remove trailing slash if exists
const currentUrlPath = Astro.url.pathname.replace(/\/+$/, "");

// Get url array from path, excluding the BASE_URL segments
const baseSegments = import.meta.env.BASE_URL.split("/").filter(Boolean);
const breadcrumbList = currentUrlPath
  .split("/")
  .filter(Boolean)
  .filter(segment => !baseSegments.includes(segment));

// if breadcrumb is Home > Posts > 1 <etc>
// replace Posts with Posts (page number)
if (breadcrumbList[0] === "posts") {
  breadcrumbList.splice(0, 2, `Статьи (стр. ${breadcrumbList[1] || 1})`);
}

// if breadcrumb is Home > Tags > [tag] > [page] <etc>
// replace [tag] > [page] with [tag] (page number)
if (breadcrumbList[0] === "tags" && !isNaN(Number(breadcrumbList[2]))) {
  breadcrumbList.splice(
    1,
    3,
    `${breadcrumbList[1]} ${Number(breadcrumbList[2]) === 1 ? "" : "(стр. " + breadcrumbList[2] + ")"}`
  );
}
const breadcrumbMap: Record<string, string> = {
  about: "О проекте",
  tags: "Теги",
  posts: "Статьи",
  search: "Поиск",
  archives: "Архивы",
};
---

<nav class="app-layout mt-8 mb-1" aria-label="breadcrumb">
  <ul
    class="font-light [&>li]:inline [&>li:not(:last-child)>a]:hover:opacity-100"
  >
    <li>
      <a href={import.meta.env.BASE_URL} class="opacity-80">Главная</a>
      <span aria-hidden="true" class="opacity-80">&raquo;</span>
    </li>
    {
      breadcrumbList.map((breadcrumb, index) =>
        index + 1 === breadcrumbList.length ? (
          <li>
            <span
              class="opacity-75"
              aria-current="page"
            >
              {/* make the last part lowercase in Home > Tags > some-tag */}
              {breadcrumbMap[breadcrumb] || decodeURIComponent(breadcrumb)}
            </span>
          </li>
        ) : (
          <li>
            <a
              href={`${import.meta.env.BASE_URL}${breadcrumb}/`.replace(
                /\/+/g,
                "/"
              )}
              class="opacity-70"
            >
              {breadcrumbMap[breadcrumb] || breadcrumb}
            </a>
            <span aria-hidden="true">&raquo;</span>
          </li>
        )
      )
    }
  </ul>
</nav>
